{
  "name": "temple-webapp",
  "version": "0.0.75",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node scripts/inject-meta-tags.js",
    "build": "npm run build:dev",
    "build:dev": "ng build",
    "build:prod": "ng build --configuration production && npm run postbuild",
    "build:prod:git": "ng build --configuration=production --base-href=/temple-webapp/ && npm run postbuild",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "postbuild": "node scripts/postbuild.js",
    "deploy:gitpages": "node scripts/deploy.js",
    "lint": "eslint \"src/**/*.{ts,html}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss}\"",
    "deploy:firebase": "node scripts/deploy-firebase.js",
    "deploy:all-opt": "npm run deploy:firebase -- --no-commit && npm run deploy -- --no-version",
    "deploy:all": "npm run deploy:firebase"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "firebase": "^12.13.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/cli": "21.2.10",
    "@angular/compiler-cli": "21.2.12",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jasmine": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "firebase-tools": "^15.17.0",
    "jasmine-core": "^6.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.0"
  }
}
